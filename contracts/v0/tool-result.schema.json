{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/spec/v0/tool-result.schema.json",
  "title": "Agent Runtime ToolOutput",
  "oneOf": [
    { "$ref": "#/$defs/observation" },
    { "$ref": "#/$defs/acceptance" },
    { "$ref": "#/$defs/rejection" },
    { "$ref": "#/$defs/extension_output" }
  ],
  "$defs": {
    "observation": {
      "type": "object",
      "required": ["kind", "parts", "is_error"],
      "properties": {
        "kind": { "const": "observation" },
        "parts": {
          "type": "array",
          "items": {
            "$ref": "messages.schema.json#/$defs/content_part"
          }
        },
        "metadata": {
          "type": "object"
        },
        "is_error": {
          "type": "boolean"
        },
        "pause": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/pause_request" }
          ]
        },
        "background_task": {
          "$ref": "#/$defs/background_task"
        }
      },
      "additionalProperties": false
    },
    "acceptance": {
      "type": "object",
      "required": ["kind", "parts", "correlation_id"],
      "properties": {
        "kind": { "const": "acceptance" },
        "parts": {
          "type": "array",
          "items": {
            "$ref": "messages.schema.json#/$defs/content_part"
          }
        },
        "correlation_id": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object"
        },
        "background_task": {
          "$ref": "#/$defs/background_task"
        }
      },
      "additionalProperties": false
    },
    "rejection": {
      "type": "object",
      "required": ["kind", "parts", "is_error"],
      "properties": {
        "kind": { "const": "rejection" },
        "parts": {
          "type": "array",
          "items": {
            "$ref": "messages.schema.json#/$defs/content_part"
          }
        },
        "metadata": {
          "type": "object"
        },
        "is_error": {
          "const": true
        },
        "correlation_id": {
          "type": "string",
          "minLength": 1
        },
        "background_task": {
          "$ref": "#/$defs/background_task"
        }
      },
      "additionalProperties": false
    },
    "extension_output": {
      "type": "object",
      "required": ["kind", "parts"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1,
          "not": { "enum": ["observation", "acceptance", "rejection"] }
        },
        "parts": {
          "type": "array",
          "items": {
            "$ref": "messages.schema.json#/$defs/content_part"
          }
        },
        "metadata": {
          "type": "object"
        },
        "is_error": {
          "type": "boolean"
        },
        "pause": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/pause_request" }
          ]
        },
        "correlation_id": {
          "type": "string",
          "minLength": 1
        },
        "background_task": {
          "$ref": "#/$defs/background_task"
        }
      },
      "additionalProperties": false
    },
    "background_task": {
      "type": "object",
      "required": ["id", "status", "kind", "lifecycle", "metadata"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "lifecycle": { "type": "string", "enum": ["started", "updated", "completed"] },
        "correlation_id": { "type": "string", "minLength": 1 },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "pause_request": {
      "type": "object",
      "required": ["reason", "source", "wait_id", "metadata", "interrupt"],
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "wait_id": {
          "type": ["string", "null"]
        },
        "metadata": {
          "type": "object"
        },
        "interrupt": {
          "const": false
        }
      },
      "additionalProperties": false
    }
  }
}
