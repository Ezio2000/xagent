{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jharness.invalid/spec/v0/model-request.schema.json",
  "title": "Kernel v0 Model Request",
  "type": "object",
  "required": ["messages", "tools", "options", "tool_choice", "response_format"],
  "properties": {
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "messages.schema.json#/$defs/message" }
    },
    "tools": {
      "type": "array",
      "$comment": "Tool names must be unique; SDK semantic validation enforces uniqueness by name.",
      "items": { "$ref": "tools.schema.json#/$defs/tool_spec" }
    },
    "options": { "$ref": "#/$defs/model_options" },
    "tool_choice": { "$ref": "#/$defs/tool_choice" },
    "response_format": {
      "oneOf": [
        { "$ref": "#/$defs/response_format" },
        { "type": "null" }
      ]
    }
  },
  "$defs": {
    "model_options": {
      "type": "object",
      "required": ["model", "temperature", "top_p", "max_output_tokens", "stop", "seed", "metadata"],
      "properties": {
        "model": { "type": ["string", "null"] },
        "temperature": { "type": ["number", "null"] },
        "top_p": { "type": ["number", "null"] },
        "max_output_tokens": { "type": ["integer", "null"], "minimum": 1 },
        "stop": {
          "oneOf": [
            {
              "type": "array",
              "items": { "type": "string" }
            },
            { "type": "null" }
          ]
        },
        "seed": { "type": ["integer", "null"] },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "tool_choice": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "allow_parallel_tool_calls"],
          "properties": {
            "type": { "enum": ["auto", "none", "required"] },
            "allow_parallel_tool_calls": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "name", "allow_parallel_tool_calls"],
          "properties": {
            "type": { "const": "named" },
            "name": { "type": "string", "minLength": 1 },
            "allow_parallel_tool_calls": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      ]
    },
    "response_format": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type"],
          "properties": { "type": { "const": "text" } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": { "type": { "const": "json_object" } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "schema", "strict"],
          "properties": {
            "type": { "const": "json_schema" },
            "schema": { "type": ["object", "boolean"] },
            "strict": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
