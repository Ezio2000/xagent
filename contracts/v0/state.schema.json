{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/spec/v0/state.schema.json",
  "title": "Agent Runtime State",
  "type": "object",
  "required": [
    "status",
    "messages",
    "pending_tool_calls",
    "iterations",
    "total_tool_calls",
    "total_usage",
    "final_parts",
    "error",
    "pause"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["planning", "executing_tools", "paused", "completed", "failed", "limit_exceeded"]
    },
    "messages": {
      "type": "array",
      "items": {
        "$ref": "messages.schema.json"
      }
    },
    "pending_tool_calls": {
      "type": "array",
      "items": {
        "$ref": "messages.schema.json#/$defs/tool_call"
      }
    },
    "iterations": {
      "type": "integer",
      "minimum": 0
    },
    "total_tool_calls": {
      "type": "integer",
      "minimum": 0
    },
    "total_usage": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/usage" }
      ]
    },
    "final_parts": {
      "type": "array",
      "items": {
        "$ref": "messages.schema.json#/$defs/content_part"
      }
    },
    "error": {
      "type": ["string", "null"]
    },
    "pause": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/pause_state" }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "const": "paused" }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "pause": { "$ref": "#/$defs/pause_state" }
        }
      },
      "else": {
        "properties": {
          "pause": { "type": "null" }
        }
      }
    }
  ],
  "$defs": {
    "usage": {
      "type": "object",
      "properties": {
        "input_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "output_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "total_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "reasoning_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "cache_read_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "cache_write_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "pause_state": {
      "type": "object",
      "required": ["reason", "resume_status", "source", "wait_id", "metadata"],
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "resume_status": {
          "type": "string",
          "enum": ["planning", "executing_tools"]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "wait_id": {
          "type": ["string", "null"]
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
