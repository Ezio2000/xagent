{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jharness.invalid/spec/v0/model-response.schema.json",
  "title": "Kernel v0 Model Response",
  "type": "object",
  "required": ["parts", "tool_calls", "finish_reason", "usage", "model_id", "response_id", "metadata"],
  "properties": {
    "parts": {
      "type": "array",
      "items": { "$ref": "messages.schema.json#/$defs/content_part" }
    },
    "tool_calls": {
      "type": "array",
      "items": { "$ref": "messages.schema.json#/$defs/tool_call" }
    },
    "finish_reason": { "type": ["string", "null"] },
    "usage": {
      "oneOf": [
        { "$ref": "#/$defs/model_usage" },
        { "type": "null" }
      ]
    },
    "model_id": { "type": ["string", "null"] },
    "response_id": { "type": ["string", "null"] },
    "metadata": { "type": "object" }
  },
  "$defs": {
    "model_usage": {
      "type": "object",
      "required": ["input_tokens", "output_tokens", "total_tokens", "reasoning_tokens", "cache_read_tokens", "cache_write_tokens"],
      "properties": {
        "input_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "output_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "total_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "reasoning_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "cache_read_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "cache_write_tokens": { "type": ["integer", "null"], "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "anyOf": [
    { "properties": { "parts": { "minItems": 1 } } },
    { "properties": { "tool_calls": { "minItems": 1 } } }
  ],
  "additionalProperties": false
}
