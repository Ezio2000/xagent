{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/spec/v0/model-error.schema.json",
  "title": "Agent Runtime Model Error Info",
  "type": "object",
  "required": ["message"],
  "properties": {
    "message": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "code": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "status_code": {
      "type": ["integer", "null"],
      "minimum": 100
    },
    "retryable": {
      "type": "boolean"
    },
    "request_id": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
