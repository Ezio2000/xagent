{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/spec/v0/tools.schema.json",
  "title": "Agent Runtime ToolSpec",
  "type": "object",
  "required": ["name", "description", "input_schema", "modes"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "input_schema": {
      "type": "object",
      "description": "JSON Schema used by runtimes to validate tool invocation arguments before calling the tool implementation."
    },
    "modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Invocation modes supported by this tool. Core runtimes recognize execute and accept; other non-empty modes are extension points handled by tool implementations."
    },
    "output_schema": {
      "type": ["object", "null"]
    },
    "annotations": {
      "type": "object",
      "description": "Open scheduling and safety hints. Core schedulers recognize parallel_safe, read_only, and idempotent boolean hints. Approval-aware runtimes may normalize a nested risk object."
    },
    "metadata": {
      "type": "object"
    }
  },
  "$defs": {
    "risk": {
      "type": "object",
      "properties": {
        "filesystem": { "type": "string", "minLength": 1 },
        "network": { "type": "string", "minLength": 1 },
        "subprocess": { "type": "boolean" },
        "destructive": { "type": "boolean" },
        "requires_approval": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "annotations": {
            "required": ["risk"]
          }
        },
        "required": ["annotations"]
      },
      "then": {
        "properties": {
          "annotations": {
            "properties": {
              "risk": { "$ref": "#/$defs/risk" }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
