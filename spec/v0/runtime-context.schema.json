{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/spec/v0/runtime-context.schema.json",
  "title": "Agent Runtime Context",
  "type": "object",
  "required": ["run_id", "started_at", "deadline", "metadata", "sequence"],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "started_at": {
      "type": "number",
      "description": "Wall-clock epoch seconds when the run context was created."
    },
    "deadline": {
      "type": ["number", "null"],
      "description": "Wall-clock epoch seconds when the run should expire, or null."
    },
    "metadata": {
      "type": "object"
    },
    "parent_run_id": {
      "type": "string",
      "minLength": 1,
      "description": "Optional run id of the parent run that created this child run."
    },
    "parent_tool_call_id": {
      "type": "string",
      "minLength": 1,
      "description": "Optional tool-call id in the parent run that created this child run."
    },
    "run_kind": {
      "type": "string",
      "minLength": 1,
      "description": "Optional host-defined run kind, such as subagent."
    },
    "sequence": {
      "type": "integer",
      "minimum": 0
    }
  },
  "allOf": [
    {
      "if": {
        "anyOf": [
          { "required": ["parent_tool_call_id"] },
          { "required": ["run_kind"] }
        ]
      },
      "then": { "required": ["parent_run_id"] }
    }
  ],
  "additionalProperties": false
}
