{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/spec/v0/model-response.schema.json",
  "title": "Agent Runtime Model Response",
  "type": "object",
  "required": ["parts", "tool_calls"],
  "properties": {
    "parts": {
      "type": "array",
      "items": {
        "$ref": "messages.schema.json#/$defs/content_part"
      }
    },
    "tool_calls": {
      "type": "array",
      "$comment": "Tool call ids must be unique within this array. JSON Schema cannot portably express uniqueness by object field; SDKs must enforce it.",
      "items": {
        "$ref": "messages.schema.json#/$defs/tool_call"
      }
    },
    "finish_reason": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "usage": {
      "type": ["object", "null"],
      "properties": {
        "input_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "output_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "total_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "reasoning_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "cache_read_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "cache_write_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "model": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "response_id": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
