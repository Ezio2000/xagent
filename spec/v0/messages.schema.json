{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runtime.local/spec/v0/messages.schema.json",
  "title": "Agent Runtime Message",
  "type": "object",
  "required": ["role", "parts"],
  "properties": {
    "role": {
      "type": "string",
      "enum": ["system", "user", "assistant", "tool"]
    },
    "parts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/content_part"
      }
    },
    "tool_call_id": {
      "type": ["string", "null"]
    },
    "tool_calls": {
      "type": "array",
      "$comment": "Assistant tool call ids must be unique within this array. JSON Schema cannot portably express uniqueness by object field; SDKs must enforce it.",
      "items": {
        "$ref": "#/$defs/tool_call"
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "role": { "const": "tool" } },
        "required": ["role"]
      },
      "then": {
        "required": ["tool_call_id"],
        "properties": {
          "tool_call_id": { "type": "string", "minLength": 1 }
        }
      }
    },
    {
      "if": {
        "properties": { "role": { "not": { "const": "tool" } } },
        "required": ["role"]
      },
      "then": {
        "not": {
          "required": ["tool_call_id"],
          "properties": {
            "tool_call_id": { "type": "string" }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "role": { "not": { "const": "assistant" } } },
        "required": ["role"]
      },
      "then": {
        "properties": {
          "tool_calls": { "maxItems": 0 }
        }
      }
    }
  ],
  "$defs": {
    "content_part": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "text": { "type": "string" },
        "uri": { "type": "string" },
        "ref": { "type": "string" },
        "media_type": { "type": "string" },
        "name": { "type": "string" },
        "data": { "type": "object" },
        "metadata": { "type": "object" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "text" } },
            "required": ["type"]
          },
          "then": { "required": ["text"] }
        },
        {
          "not": { "required": ["uri", "ref"] }
        }
      ],
      "additionalProperties": false
    },
    "tool_call": {
      "type": "object",
      "required": ["id", "name", "arguments"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "arguments": { "type": "object" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
